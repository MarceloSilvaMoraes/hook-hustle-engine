# Public browser values (Vite build-time)
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your_key>

# Server-side values
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your_key>
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key>

# Google OAuth / YouTube
VITE_GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
VITE_GOOGLE_REDIRECT_URI=http://127.0.0.1:8082/youtube-callback
